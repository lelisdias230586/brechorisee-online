# BRECHORISEE v4.9.6 - Oracle Cloud VPS
BRECHORISEE_ENV=production
BRECHORISEE_VERSION=4.9.6-oracle-vps

# Antes de ter dominio, pode usar http://IP-PUBLICO-DA-ORACLE
# Depois com HTTPS, use https://app.seudominio.com.br
PUBLIC_BASE_URL=http://IP-PUBLICO-DA-ORACLE
BRECHORISEE_PUBLIC_BASE_URL=http://IP-PUBLICO-DA-ORACLE

BRECHORISEE_DB_PATH=/var/lib/brechorisee/brechorisee.db
BRECHORISEE_PERSISTENT_DIR=/var/lib/brechorisee

BRECHORISEE_CLIENT_APK_URL=http://IP-PUBLICO-DA-ORACLE/download/app-cliente.apk
BRECHORISEE_CLIENT_APP_URL=http://IP-PUBLICO-DA-ORACLE/app/cliente
BRECHORISEE_APP_DOWNLOAD_URL=http://IP-PUBLICO-DA-ORACLE/app/cliente

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=
TELEGRAM_WEBHOOK_URL=http://IP-PUBLICO-DA-ORACLE/api/telegram/webhook
