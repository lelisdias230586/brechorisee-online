# ============================================================
# BRECHORISEE - ÚNICO ARQUIVO DE CONFIGURAÇÃO
# ============================================================
# Edite somente este arquivo.
# Caminho: BRECHORISEE_SERVIDOR\app\.env
#
# Este arquivo serve para:
# - Notebook Windows
# - Celular Android servidor via Termux
# - Cliente Android
# - Admin Android
# - Telegram
# - Banco local
#
# Não envie este arquivo com senhas/tokens para ninguém.
# ============================================================

APP_ENV=production
BRECHORISEE_ENV=production
BRECHORISEE_VERSION=4.9.3-inventario-telegram
BRECHORISEE_STORE_NAME=BRECHORISEE

# URL do servidor.
# Servidor oficial da BRECHORISEE: celular servidor.
# Use este endereço no PC, Admin e Cliente.
PUBLIC_BASE_URL=http://100.121.45.12:8000
BRECHORISEE_PUBLIC_BASE_URL=http://100.121.45.12:8000
BRECHORISEE_PUBLIC_URL=http://100.121.45.12:8000
BRECHORISEE_SERVER_URL=http://100.121.45.12:8000
BRECHORISEE_ADMIN_SERVER_URL=http://100.121.45.12:8000
BRECHORISEE_CLIENT_SERVER_URL=http://100.121.45.12:8000

# Banco local único.
# Funciona no Windows modular e no Termux porque o app resolve este caminho
# a partir de BRECHORISEE_SERVIDOR/app/brechorisee_app.
BRECHORISEE_DB_PATH=../../dados/brechorisee.db

# Tokens internos
BRECHORISEE_SYNC_TOKEN=PREENCHER_NO_SEU_AMBIENTE
BRECHORISEE_ASSISTANT_TOKEN=PREENCHER_NO_SEU_AMBIENTE

